VITE_UNLEASH_URL=http://localhost:4242/api/frontend
VITE_UNLEASH_CLIENT_KEY=
VITE_UNLEASH_APP_NAME=frontend

# Deployed (Vercel) values point at the hosted getunleash.io instance instead of
# localhost, and use a Frontend API token scoped to the matching Unleash
# environment. These are set as Environment Variables in Vercel project settings
# (scoped per Vercel environment below), never committed here:
#
#   Vercel "Preview"    -> VITE_UNLEASH_URL=https://<your-instance>.getunleash.io/api/frontend
#                          VITE_UNLEASH_CLIENT_KEY=<frontend token for the "development" Unleash env>
#   Vercel "Production" -> VITE_UNLEASH_URL=https://<your-instance>.getunleash.io/api/frontend
#                          VITE_UNLEASH_CLIENT_KEY=<frontend token for the "production" Unleash env>
#
# See the root README's "Deployed environments (Vercel)" section for full steps.
