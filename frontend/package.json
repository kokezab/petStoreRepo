{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint:check": "eslint .",
    "lint": "eslint . --fix",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" \"*.json\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"*.json\"",
    "format:lint": "npm run format && npm run lint",
    "check": "tsc -b && eslint . && prettier --check \"src/**/*.{ts,tsx,css,json}\" \"*.json\"",
    "generate:api": "orval",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:acceptance": "bddgen && playwright test --grep @sig",
    "test:ui": "playwright test --ui",
    "prepare": "git config core.hooksPath .husky"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@unleash/proxy-client-react": "^6.0.0",
    "antd": "^6.5.0",
    "axios": "^1.18.1",
    "immer": "^11.1.11",
    "qs": "^6.15.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0",
    "unleash-proxy-client": "^3.8.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.13.2",
    "@types/qs": "^6.15.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "orval": "^8.20.0",
    "playwright-bdd": "^9.2.0",
    "prettier": "^3.9.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
